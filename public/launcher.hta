<html>
<head>
  <title>Tycoon Stream Bridge</title>
  <hta:application
    applicationname="TycoonStreamBridge"
    border="thin"
    caption="yes"
    contextmenu="no"
    maximizebutton="no"
    minimizebutton="yes"
    navigable="yes"
    scroll="no"
    selection="no"
    showintaskbar="yes"
    singleinstance="yes"
    sysmenu="yes"
    windowstate="normal"
  />
  <meta http-equiv="x-ua-compatible" content="IE=9" />
  <style>
    html, body {
      margin: 0;
      padding: 0;
      width: 100%;
      height: 100%;
      overflow: hidden;
      font-family: "Segoe UI", Arial, sans-serif;
      background: #0b0f18;
      color: #eef4ff;
    }
    body {
      background:
        radial-gradient(circle at 18% 0%, rgba(90,182,255,0.18), transparent 40%),
        radial-gradient(circle at 82% 0%, rgba(158,123,255,0.16), transparent 36%),
        #0b0f18;
    }
    .shell {
      padding: 16px 16px 14px;
    }
    .topbar {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 12px;
    }
    .brand {
      display: flex;
      align-items: center;
      gap: 10px;
      font-weight: 700;
      font-size: 19px;
    }
    .brand-icon {
      width: 34px;
      height: 34px;
      border-radius: 10px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      background: linear-gradient(135deg, #5ab6ff, #9e7bff);
      color: #fff;
      font-size: 18px;
      box-shadow: 0 8px 24px rgba(90,182,255,0.22);
    }
    .status-pill {
      padding: 7px 12px;
      border-radius: 999px;
      background: rgba(255,255,255,0.05);
      border: 1px solid rgba(255,255,255,0.08);
      font-size: 12px;
      font-weight: 700;
      letter-spacing: 0.04em;
      text-transform: uppercase;
    }
    .status-pill.good {
      color: #43d17c;
      border-color: rgba(67,209,124,0.35);
      background: rgba(67,209,124,0.08);
    }
    .status-pill.bad {
      color: #ff667a;
      border-color: rgba(255,102,122,0.3);
      background: rgba(255,102,122,0.08);
    }
    .hero {
      border-radius: 14px;
      padding: 18px 16px 16px;
      margin-bottom: 12px;
      background: linear-gradient(180deg, rgba(19,28,45,0.98), rgba(24,36,58,0.98));
      border: 1px solid rgba(255,255,255,0.08);
    }
    .hero-title {
      font-size: 22px;
      font-weight: 800;
      margin-bottom: 5px;
    }
    .hero-sub {
      color: #96a8c6;
      font-size: 13px;
      line-height: 1.45;
    }
    .hero-note {
      margin-top: 8px;
      font-size: 12px;
      color: #b9c9e3;
    }
    .actions {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 9px;
      margin-bottom: 12px;
    }
    .btn {
      border: 0;
      border-radius: 12px;
      padding: 12px 14px;
      font: inherit;
      font-size: 14px;
      font-weight: 700;
      cursor: pointer;
      color: #eef4ff;
      background: rgba(255,255,255,0.05);
      border: 1px solid rgba(255,255,255,0.08);
      text-align: center;
    }
    .btn-wide {
      grid-column: 1 / -1;
    }
    .btn.primary {
      background: linear-gradient(135deg, #5ab6ff, #9e7bff);
      border-color: transparent;
      box-shadow: 0 8px 24px rgba(90,182,255,0.22);
    }
    .btn.secondary:hover {
      border-color: rgba(90,182,255,0.55);
    }
    .footer {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 10px;
      font-size: 12px;
      color: #96a8c6;
    }
    .bridge-url {
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
      max-width: 72%;
    }
    .footer a {
      color: #5ab6ff;
      text-decoration: none;
    }
    .footer-links {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      white-space: nowrap;
    }
  </style>
  <script>
    var bridgeBase = 'http://127.0.0.1:21420';

    function setStatus(connected, subtitle) {
      var pill = document.getElementById('status-pill');
      var title = document.getElementById('hero-title');
      var sub = document.getElementById('hero-sub');
      pill.className = 'status-pill ' + (connected ? 'good' : 'bad');
      pill.innerHTML = connected ? 'Connected' : 'Disconnected';
      title.innerHTML = connected ? 'TikFinity connected' : 'Waiting for TikFinity';
      sub.innerHTML = subtitle || (connected
        ? 'Stream chat is live. Open a game below and your local bridge will feed it automatically.'
        : 'Open TikFinity on this computer, then leave this window running while you stream.');
    }

    function refreshStatus() {
      var xhr = new XMLHttpRequest();
      xhr.open('GET', bridgeBase + '/health?_=' + new Date().getTime(), true);
      xhr.onreadystatechange = function () {
        if (xhr.readyState !== 4) return;
        if (xhr.status >= 200 && xhr.status < 300) {
          try {
            var data = JSON.parse(xhr.responseText || '{}');
            setStatus(!!data.tickfinityConnected, data.tickfinityConnected
              ? 'Receiving live events from ' + (data.tickfinityUrl || 'ws://127.0.0.1:21213')
              : 'Trying ' + (data.tickfinityUrl || 'ws://127.0.0.1:21213') + '. Start TikFinity if nothing is happening.');
          } catch (e) {
            setStatus(false, 'The bridge is running, but the status response was not valid JSON.');
          }
        } else {
          setStatus(false, 'The local bridge is still starting. Wait a moment and it should connect.');
        }
      };
      xhr.send();
    }

    function openUrl(url) {
      try {
        var shell = new ActiveXObject('WScript.Shell');
        shell.Run('"' + url + '"', 1, false);
      } catch (e) {
        window.open(url);
      }
    }

    function init() {
      try {
        window.resizeTo(560, 560);
      } catch (e) {}
      refreshStatus();
      window.setInterval(refreshStatus, 2500);
    }
  </script>
</head>
<body onload="init()">
  <div class="shell">
    <div class="topbar">
      <div class="brand">
        <div class="brand-icon">&#9889;</div>
        <div>Tycoon Stream Bridge</div>
      </div>
      <div class="status-pill bad" id="status-pill">Starting</div>
    </div>

    <div class="hero">
      <div class="hero-title" id="hero-title">Starting bridge</div>
      <div class="hero-sub" id="hero-sub">Launching the local dashboard now.</div>
      <div class="hero-note">Leave this app open while you stream.</div>
    </div>

    <div class="actions">
      <button class="btn primary btn-wide" onclick="openUrl('http://127.0.0.1:21420/')">Open Dashboard</button>
      <button class="btn secondary" onclick="openUrl('https://rectangled.live/stream')">Open RecTangled</button>
      <button class="btn secondary" onclick="openUrl('https://erectangled.com/stream')">Open eRecTangled</button>
      <button class="btn secondary btn-wide" onclick="openUrl('https://searchle.live/stream')">Open Searchle</button>
    </div>

    <div class="footer">
      <span class="bridge-url">Bridge URL: 127.0.0.1:21420</span>
      <span class="footer-links">
        <a href="#" onclick="openUrl('https://wordtycoon.live/streambridge'); return false;">Help</a>
        <a href="#" onclick="openUrl('https://github.com/johnrstanley11-gif/tycoon-stream-bridge'); return false;">Source</a>
      </span>
    </div>
  </div>
</body>
</html>
