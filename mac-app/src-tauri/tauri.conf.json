{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Tycoon Stream Bridge",
  "version": "0.1.0",
  "identifier": "live.wordgame.tikfinitystreambridge",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Tycoon Stream Bridge",
        "width": 980,
        "height": 760,
        "minWidth": 860,
        "minHeight": 700,
        "resizable": true,
        "center": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": [
      "app",
      "dmg"
    ],
    "createUpdaterArtifacts": false,
    "externalBin": [
      "binaries/TycoonStreamBridge"
    ],
    "icon": [
      "icons/wordtycoon-logo.png"
    ],
    "macOS": {
      "minimumSystemVersion": "12.0"
    }
  }
}
